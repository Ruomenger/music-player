{
  "version": 6,
  "cmakeMinimumRequired": { "major": 4, "minor": 3, "patch": 2 },
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{HOME}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "_linux-x64",
      "hidden": true,
      "inherits": "_base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "_macos-arm64",
      "hidden": true,
      "inherits": "_base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_PREFIX_PATH": "/opt/homebrew/opt/qt;/opt/homebrew/opt/portaudio",
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++"
      }
    },
    {
      "name": "linux-x64-debug",
      "displayName": "Linux x64 (Debug)",
      "inherits": "_linux-x64",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "linux-x64-release",
      "displayName": "Linux x64 (Release)",
      "inherits": "_linux-x64",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "macos-arm64-debug",
      "displayName": "macOS arm64 (Debug)",
      "inherits": "_macos-arm64",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "macos-arm64-release",
      "displayName": "macOS arm64 (Release)",
      "inherits": "_macos-arm64",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "_ci-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "ci-debug",
      "displayName": "CI Debug",
      "inherits": "_ci-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_SANITIZERS": "OFF",
        "ENABLE_COVERAGE": "OFF"
      }
    },
    {
      "name": "ci-asan",
      "displayName": "CI ASan+UBSan",
      "inherits": "_ci-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_SANITIZERS": "ON",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer"
      }
    },
    {
      "name": "ci-coverage",
      "displayName": "CI Coverage",
      "inherits": "_ci-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_COVERAGE": "ON",
        "CMAKE_CXX_FLAGS": "--coverage -O0 -g"
      }
    }
  ],
  "buildPresets": [
    { "name": "linux-x64-debug",     "configurePreset": "linux-x64-debug" },
    { "name": "linux-x64-release",   "configurePreset": "linux-x64-release" },
    { "name": "macos-arm64-debug",   "configurePreset": "macos-arm64-debug" },
    { "name": "macos-arm64-release", "configurePreset": "macos-arm64-release" },
    { "name": "ci-debug",            "configurePreset": "ci-debug" },
    { "name": "ci-asan",             "configurePreset": "ci-asan" },
    { "name": "ci-coverage",         "configurePreset": "ci-coverage" }
  ],
  "testPresets": [
    {
      "name": "linux-x64-debug",
      "configurePreset": "linux-x64-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "macos-arm64-debug",
      "configurePreset": "macos-arm64-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ci-debug",
      "configurePreset": "ci-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ci-asan",
      "configurePreset": "ci-asan",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ci-coverage",
      "configurePreset": "ci-coverage",
      "output": { "outputOnFailure": true }
    }
  ]
}